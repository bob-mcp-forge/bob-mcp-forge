# Bob MCP Forge — Docker Compose Environment Variables
# Copy to .env and fill in values as needed.
# All secrets are optional — API works without them in dev mode.

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# MongoDB connection string. Compose default points to the `mongo` service.
MONGODB_URI=mongodb://mongo:27017/bob-mcp-forge

# IBM Bob / generator credentials (set when available)
# BOB_API_KEY=your-bob-api-key-here
# BOB_API_URL=https://bob.ibm.com

# IBM Cloud (required only for deploy feature)
# IBM_CLOUD_API_KEY=your-api-key-here
# IBM_CLOUD_REGION=us-south
